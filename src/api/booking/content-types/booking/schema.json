{
  "kind": "collectionType",
  "collectionName": "bookings",
  "info": {
    "singularName": "booking",
    "pluralName": "bookings",
    "displayName": "Booking"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "guestName": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "checkIn": {
      "type": "datetime"
    },
    "checkOut": {
      "type": "datetime"
    },
    "room": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::room.room",
      "inversedBy": "bookings"
    },
    "numberOfGuests": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "totalPrice": {
      "type": "decimal",
      "min": 0
    },
    "statuss": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "confirmed",
        "cancelled"
      ]
    },
    "specialRequests": {
      "type": "text"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "room"
    },
    "paymentScreenshot": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    },
    "paymentNote": {
      "type": "text"
    }
  }
}
