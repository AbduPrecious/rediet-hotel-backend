{
    "kind": "collectionType",
    "collectionName": "rooms",
    "info": {
        "singularName": "room",
        "pluralName": "rooms",
        "displayName": "Room"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string"
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "description": {
            "type": "blocks",
            "required": true
        },
        "price": {
            "type": "decimal"
        },
        "capacity": {
            "type": "integer",
            "min": 1,
            "max": 10
        },
        "images": {
            "type": "media",
            "multiple": true,
            "required": true,
            "allowedTypes": [
                "images"
            ]
        },
        "featured": {
            "type": "boolean",
            "default": false
        },
        "amenities": {
            "type": "json"
        },
        "bookings": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::booking.booking",
            "mappedBy": "room"
        },
        "reviews": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::review.review",
            "mappedBy": "relatedRoom"
        }
    }
}
