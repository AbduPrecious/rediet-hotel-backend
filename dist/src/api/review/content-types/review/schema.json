{
    "kind": "collectionType",
    "collectionName": "reviews",
    "info": {
        "singularName": "review",
        "pluralName": "reviews",
        "displayName": "Review"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "guestName": {
            "type": "string",
            "required": true
        },
        "rating": {
            "type": "integer",
            "required": true
        },
        "comment": {
            "type": "text"
        },
        "room": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::booking.booking",
            "inversedBy": "reviews"
        },
        "booking": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::booking.booking"
        },
        "dateOfStay": {
            "type": "date"
        },
        "avatar": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        },
        "relatedRoom": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::room.room",
            "inversedBy": "reviews"
        }
    }
}
